{
  "tasks": [
    {
      "id": "morning-summary",
      "name": "Morning Summary",
      "workspaceId": "shared",
      "cron": "0 9 * * *",
      "enabled": true,
      "action": {
        "type": "invoke_claude",
        "payload": {
          "prompt": "请总结昨天所有未处理的消息",
          "send_to": { "chat_id": "oc_xxx" }
        }
      }
    },
    {
      "id": "cleanup-media",
      "name": "Cleanup Old Media",
      "workspaceId": "shared",
      "cron": "0 2 * * *",
      "enabled": true,
      "action": {
        "type": "cleanup_media",
        "payload": { "max_age_days": 7 }
      }
    },
    {
      "id": "daily-report-reminder",
      "name": "Daily Report Reminder",
      "workspaceId": "default",
      "cron": "0 18 * * 1-5",
      "enabled": true,
      "action": {
        "type": "send_message",
        "payload": { "chat_id": "oc_xxx", "text": "请记得填写今日日报" }
      }
    }
  ]
}
