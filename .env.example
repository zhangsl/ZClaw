# Claude
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-7
CLAUDE_MAX_TOKENS=4096

# ZClaw
ZCLAW_DATA_DIR=./data
ZCLAW_LOG_LEVEL=info
ZCLAW_SESSION_MAX_MESSAGES=20
ZCLAW_SESSION_TTL_MS=3600000
ZCLAW_MEDIA_MAX_MB=30

# lark-cli path (optional, defaults to searching PATH)
LARK_CLI_PATH=/usr/local/bin/lark

# Multi-account Feishu config (JSON file path)
ZCLAW_ACCOUNTS_CONFIG=./accounts.json

# Scheduled tasks config (JSON file path)
ZCLAW_TASKS_CONFIG=./tasks.json
